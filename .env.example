# ============================================================
# Nexa Drill — variáveis de ambiente (template)
# Copie para .env.local e preencha. .env.local é git-ignored.
# NUNCA commitar segredos reais.
# ============================================================

# ── Banco (Supabase / Postgres) ──────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_ROLE_SECRET=
SUPABASE_JWKS_URL=

# ── Auth (better-auth) ───────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# ── SMTP (envio de e-mail / OTP) ─────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── LLM (OpenRouter) ─────────────────────────────────────────
OPENROUTER_API_KEY=
LLM_MODEL=

# ── Asaas (gateway de pagamento — Fase 2) ────────────────────
# Ver docs/integracoes.md para setup completo.
# Sandbox:  https://api-sandbox.asaas.com/v3  (confirmar no painel)
# Produção: https://api.asaas.com/v3
#
# ATENÇÃO: a chave do Asaas começa com "$". No .env ela PRECISA ser escapada
# com barra invertida (ex.: ASAAS_API_KEY=\$aact_prod_xxx), senão o Next.js
# expande o "$" como variável e o valor vira vazio.
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=            # chave de PRODUÇÃO (\$aact_prod_...)
ASAAS_API_KEY_SANDBOX=    # chave de SANDBOX (\$aact_hmlg_...) — usada quando a URL é sandbox
# Token que você define no painel do Asaas e o webhook devolve para validação.
ASAAS_WEBHOOK_TOKEN=

# ── Cron (atualização diária de parcelas atrasadas) ──────────
# String aleatória. Use no header Authorization: Bearer <CRON_SECRET>
# ao agendar GET /api/cron/atualizar-parcelas (Vercel Cron etc.).
CRON_SECRET=
